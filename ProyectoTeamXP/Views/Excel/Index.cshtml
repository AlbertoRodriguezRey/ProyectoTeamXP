@{
    ViewData["Title"] = "Gestión de Excel - Seguimiento de Clientes";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="bi bi-file-earmark-excel"></i> Gestión de Excel
            </h1>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row">
                <!-- Card de Importar -->
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-upload"></i> Importar Excel
                            </h5>
                            <p class="card-text text-muted">
                                Sube un archivo Excel con los datos del seguimiento de un cliente.
                            </p>
                            
                            <form asp-action="ImportarExcel" asp-controller="Excel" method="post" enctype="multipart/form-data">
                                <div class="mb-3">
                                    <label for="archivo" class="form-label">Selecciona el archivo Excel</label>
                                    <input type="file" class="form-control" id="archivo" name="archivo" accept=".xlsx,.xls" required>
                                    <small class="form-text text-muted">
                                        Formatos aceptados: .xlsx, .xls (máximo 10MB)
                                    </small>
                                </div>
                                
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-cloud-upload"></i> Importar Excel
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Card de Listar Clientes -->
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-people"></i> Clientes con Datos
                            </h5>
                            <p class="card-text text-muted">
                                Ver la lista de clientes y exportar sus datos a Excel.
                            </p>
                            
                            <a asp-action="ListarClientes" asp-controller="Excel" class="btn btn-success w-100">
                                <i class="bi bi-list-ul"></i> Ver Clientes
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Información -->
            <div class="card bg-light">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-info-circle"></i> Información sobre el formato Excel
                    </h6>
                    <ul class="mb-0">
                        <li>El archivo debe seguir el formato estándar del seguimiento TEAM XP</li>
                        <li>Incluye: perfil del cliente, macros, medidas corporales y seguimiento diario</li>
                        <li>Los datos existentes del cliente serán actualizados o reemplazados</li>
                        <li>Puedes exportar el Excel de un cliente para usarlo como plantilla</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            transition: transform 0.2s;
            height: 100%;
        }
        .card:hover {
            transform: translateY(-5px);
        }
    </style>
}

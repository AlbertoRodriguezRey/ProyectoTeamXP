@model ProyectoTeamXP.Models.ClientePerfil

@{
    ViewData["Title"] = "Editar - " + Model.NombreCompleto;
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-action="Index" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Volver a clientes
        </a>
        <h1 class="mb-0 mt-1">Editar Cliente</h1>
        <p class="text-muted mb-0">@Model.NombreCompleto</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input asp-for="Id" type="hidden" />
                        <input asp-for="UsuarioSeguridadId" type="hidden" />
                        <input asp-for="FechaCreacion" type="hidden" />
                        <input asp-for="TerminosAceptados" type="hidden" />

                        <h3 class="mb-3" style="font-size:1rem">
                            <i class="bi bi-person-fill me-2" style="color:var(--primary)"></i>Datos Personales
                        </h3>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="NombreCompleto" class="auth-label"></label>
                                <input asp-for="NombreCompleto" class="form-control" />
                                <span asp-validation-for="NombreCompleto" class="auth-validation"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Edad" class="auth-label"></label>
                                <input asp-for="Edad" class="form-control" type="number" />
                                <span asp-validation-for="Edad" class="auth-validation"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="PesoInicial" class="auth-label"></label>
                                <input asp-for="PesoInicial" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="PesoInicial" class="auth-validation"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="FechaInicioPrograma" class="auth-label"></label>
                                <input asp-for="FechaInicioPrograma" class="form-control" type="date" />
                                <span asp-validation-for="FechaInicioPrograma" class="auth-validation"></span>
                            </div>
                        </div>

                        <h3 class="mb-3" style="font-size:1rem">
                            <i class="bi bi-bullseye me-2" style="color:var(--primary)"></i>Objetivos
                        </h3>

                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="Objetivos" class="auth-label"></label>
                                <textarea asp-for="Objetivos" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ObjetivoPasos" class="auth-label"></label>
                                <input asp-for="ObjetivoPasos" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ObjetivoCardio" class="auth-label"></label>
                                <input asp-for="ObjetivoCardio" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Suplementacion" class="auth-label"></label>
                                <textarea asp-for="Suplementacion" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-floppy-fill me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model List<ProyectoTeamXP.Models.ClientePerfil>

@{
    ViewData["Title"] = "Clientes";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="section-badge">Panel Admin</span>
            <h1 class="mb-0">Clientes</h1>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-2"></i>Nuevo Cliente
        </a>
    </div>

    @if (TempData["MENSAJE"] != null)
    {
        <div class="alert alert-success fade-up">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["MENSAJE"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-people" style="font-size:4rem; color:var(--text-muted)"></i>
            <p class="mt-3 text-muted">No hay clientes registrados aún.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">Añadir primer cliente</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark-custom mb-0">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Email</th>
                                <th>Edad</th>
                                <th>Peso Inicial</th>
                                <th>Inicio Programa</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:36px;height:36px;background:var(--primary);border-radius:50%;display:grid;place-items:center;font-weight:700;font-size:.85rem;flex-shrink:0">
                                                @cliente.NombreCompleto.Substring(0, 1).ToUpper()
                                            </div>
                                            <span class="fw-semibold">@cliente.NombreCompleto</span>
                                        </div>
                                    </td>
                                    <td class="text-muted small">@(cliente.UsuarioSeguridad?.Email ?? "—")</td>
                                    <td>@(cliente.Edad.HasValue ? $"{cliente.Edad} años" : "—")</td>
                                    <td>@(cliente.PesoInicial.HasValue ? $"{cliente.PesoInicial:F1} kg" : "—")</td>
                                    <td>@(cliente.FechaInicioPrograma.HasValue ? cliente.FechaInicioPrograma.Value.ToString("dd/MM/yyyy") : "—")</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-primary me-1" title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@cliente.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <p class="text-muted small mt-2">
            <i class="bi bi-people-fill me-1"></i>@Model.Count cliente(s) en total
        </p>
    }
</div>

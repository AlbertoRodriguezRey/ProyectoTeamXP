@model ProyectoTeamXP.Models.ClientePerfil

@{
    ViewData["Title"] = "Eliminar - " + Model.NombreCompleto;
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-action="Index" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Volver a clientes
        </a>
        <h1 class="mb-0 mt-1">Eliminar Cliente</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card" style="border-color:var(--danger)">
                <div class="card-body text-center py-4">
                    <div style="width:72px;height:72px;background:rgba(255,61,113,.15);border-radius:50%;display:grid;place-items:center;margin:0 auto 1.5rem;font-size:2rem;color:var(--danger)">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>

                    <h2 style="font-size:1.3rem">¿Eliminar este cliente?</h2>
                    <p class="text-muted mb-1">Esta acción no se puede deshacer.</p>

                    <div class="card mt-4 mb-4 text-start" style="border-color:rgba(255,255,255,.08)">
                        <div class="card-body py-3">
                            <p class="fw-bold mb-1">@Model.NombreCompleto</p>
                            <p class="text-muted small mb-0">@(Model.UsuarioSeguridad?.Email ?? "Sin email")</p>
                            @if (Model.FechaInicioPrograma.HasValue)
                            {
                                <p class="text-muted small mb-0">
                                    Desde @Model.FechaInicioPrograma.Value.ToString("dd/MM/yyyy")
                                </p>
                            }
                        </div>
                    </div>

                    <form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center">
                        <input asp-for="Id" type="hidden" />
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-x-lg me-2"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash-fill me-2"></i>Sí, eliminar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

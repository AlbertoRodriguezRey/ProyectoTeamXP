@model ProyectoTeamXP.Models.ClientePerfil

@{
    ViewData["Title"] = Model.NombreCompleto;
    var cliente = Model;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>Volver a clientes
            </a>
            <h1 class="mb-0 mt-1">@cliente.NombreCompleto</h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@cliente.Id" class="btn btn-primary">
                <i class="bi bi-pencil me-2"></i>Editar
            </a>
            <a asp-action="Delete" asp-route-id="@cliente.Id" class="btn btn-danger">
                <i class="bi bi-trash me-2"></i>Eliminar
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Datos personales -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="mb-3" style="font-size:1rem">
                        <i class="bi bi-person-fill me-2" style="color:var(--primary)"></i>Datos Personales
                    </h3>
                    <dl class="row mb-0">
                        <dt class="col-5 text-muted small">Email</dt>
                        <dd class="col-7">@(cliente.UsuarioSeguridad?.Email ?? "—")</dd>

                        <dt class="col-5 text-muted small">Edad</dt>
                        <dd class="col-7">@(cliente.Edad.HasValue ? $"{cliente.Edad} años" : "—")</dd>

                        <dt class="col-5 text-muted small">Peso Inicial</dt>
                        <dd class="col-7">@(cliente.PesoInicial.HasValue ? $"{cliente.PesoInicial:F2} kg" : "—")</dd>

                        <dt class="col-5 text-muted small">Inicio Programa</dt>
                        <dd class="col-7">@(cliente.FechaInicioPrograma.HasValue ? cliente.FechaInicioPrograma.Value.ToString("dd/MM/yyyy") : "—")</dd>

                        <dt class="col-5 text-muted small">Alta</dt>
                        <dd class="col-7">@cliente.FechaCreacion.ToString("dd/MM/yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Objetivos -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="mb-3" style="font-size:1rem">
                        <i class="bi bi-bullseye me-2" style="color:var(--primary)"></i>Objetivos
                    </h3>
                    <dl class="row mb-0">
                        <dt class="col-5 text-muted small">Objetivo</dt>
                        <dd class="col-7">@(cliente.Objetivos ?? "—")</dd>

                        <dt class="col-5 text-muted small">Pasos</dt>
                        <dd class="col-7">@(cliente.ObjetivoPasos ?? "—")</dd>

                        <dt class="col-5 text-muted small">Cardio</dt>
                        <dd class="col-7">@(cliente.ObjetivoCardio ?? "—")</dd>

                        <dt class="col-5 text-muted small">Suplementación</dt>
                        <dd class="col-7">@(cliente.Suplementacion ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Macros -->
        @if (cliente.Macros.Any())
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h3 class="mb-3" style="font-size:1rem">
                            <i class="bi bi-egg-fried me-2" style="color:var(--primary)"></i>Macronutrientes
                        </h3>
                        <div class="table-responsive">
                            <table class="table table-dark-custom mb-0">
                                <thead>
                                    <tr>
                                        <th>Tipo Día</th>
                                        <th>Proteína (g)</th>
                                        <th>Grasa (g)</th>
                                        <th>Carbohidratos (g)</th>
                                        <th>Calorías</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var macro in cliente.Macros)
                                    {
                                        <tr>
                                            <td><span class="section-badge">@macro.TipoDia</span></td>
                                            <td>@(macro.Proteina.HasValue ? $"{macro.Proteina:F1}" : "—")</td>
                                            <td>@(macro.Grasa.HasValue ? $"{macro.Grasa:F1}" : "—")</td>
                                            <td>@(macro.Carbohidratos.HasValue ? $"{macro.Carbohidratos:F1}" : "—")</td>
                                            <td>@(macro.Calorias.HasValue ? macro.Calorias.ToString() : "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
